# =====================================================================
# Research Pipeline 환경변수 템플릿
# =====================================================================
# 이 파일을 .env로 복사하고 본인의 값으로 채우세요:
#   cp .env.example .env
#
# 또는 ./start-research.sh를 처음 실행하면 대화형으로 .env가 생성됩니다.
# =====================================================================


# ── EZproxy / 도서관 프록시 설정 ────────────────────────────────────
# 본인이 속한 학교/기관에서 제공하는 EZproxy(혹은 동등 시스템) URL을 입력합니다.
# 유료 저널 전문에 접근하려면 필요합니다.
#
# PROXY_ENABLED=false 로 두면 프록시를 사용하지 않고 오픈액세스 논문만 시도합니다.
PROXY_ENABLED=true

# 프록시 베이스 URL — 원본 논문 URL을 이 뒤에 그대로 붙여 사용합니다.
# 형식이 기관마다 다르므로 도서관 안내 페이지에서 정확한 패턴을 확인하세요.
# 예시(허구):
#   https://ezproxy.your-univ.edu/login?url=
#   https://your-library.your-univ.edu/proxy?url=
#   https://your-ezproxy.your-univ.edu/link?url=
PROXY_BASE_URL=

# 프록시/도서관 로그인 페이지 URL — 자동 재로그인 시 사용됩니다.
# 예시(허구):
#   https://your-library.your-univ.edu/login
PROXY_LOGIN_URL=

# 프록시 동작 검증용 테스트 URL — 비어두면 https://www.nature.com 사용
PROXY_VERIFY_URL=

# 로그인 폼 셀렉터 — 기관마다 다를 수 있어 커스터마이징 가능합니다.
# 비어두면 기본값을 사용합니다(아이디=#user-id, 비밀번호=#user-pw,
# 제출 버튼=button[type="submit"]).
PROXY_LOGIN_ID_SELECTOR=
PROXY_LOGIN_PW_SELECTOR=
PROXY_LOGIN_SUBMIT_SELECTOR=
# (선택) 로그인 페이지에서 미리 클릭해야 하는 라디오/체크박스 셀렉터
# 예: 포털ID/직원ID 등 사용자 유형 선택 라디오
PROXY_LOGIN_PRECLICK_SELECTOR=

# 자동 로그인용 자격 증명
PROXY_PORTAL_ID=
PROXY_PORTAL_PW=


# ── 티어 1 API (전문 수집용) ─────────────────────────────────────────
# UNPAYWALL_EMAIL은 필수(아무 이메일이나 가능),
# 나머지는 선택 — 비어있으면 자동 스킵됩니다.

UNPAYWALL_EMAIL=

# Semantic Scholar (rate limit 완화용)
SEMANTIC_SCHOLAR_API_KEY=

# 출판사 TDM API (대학 구독이 있는 경우)
ELSEVIER_API_KEY=
SPRINGER_API_KEY=
SPRINGER_META_API_KEY=
WILEY_TDM_TOKEN=
CORE_API_KEY=
