# =====================================================================
# Research Pipeline 환경변수 템플릿
# =====================================================================
# 이 파일을 .env로 복사하고 본인의 값으로 채우세요:
#   cp .env.example .env
#
# 또는 ./start-research.sh를 처음 실행하면 대화형으로 .env가 생성됩니다.
# =====================================================================


# ── 연구 에이전트 선택 ──────────────────────────────────────────────
# 사용할 에이전트 CLI를 지정합니다. 사용자 환경에 해당 CLI가 설치되어
# 있어야 하며, 각 에이전트의 공식 설치/로그인 절차를 먼저 완료하세요.
#
#   claude  — Anthropic Claude Code CLI       (기본값, 가장 검증된 경로)
#   codex   — OpenAI Codex CLI                (Agent Skills 표준 호환)
#
# 실행 시 --agent 플래그로 일회성 override 가능:
#   ./start-research.sh deep --agent codex
AGENT=claude


# ── EZproxy / 도서관 프록시 설정 ────────────────────────────────────
# 본인이 속한 학교/기관에서 제공하는 EZproxy(혹은 동등 시스템) URL을 입력합니다.
# 유료 저널 전문에 접근하려면 필요합니다.
#
# PROXY_ENABLED=false 로 두면 프록시를 사용하지 않고 오픈액세스 논문만 시도합니다.
PROXY_ENABLED=true

# 프록시 베이스 URL — 원본 논문 URL을 이 뒤에 그대로 붙여 사용합니다.
# 형식이 기관마다 다르므로 도서관 안내 페이지에서 정확한 패턴을 확인하세요.
# 예시(허구):
#   https://ezproxy.your-univ.edu/login?url=
#   https://your-library.your-univ.edu/proxy?url=
#   https://your-ezproxy.your-univ.edu/link?url=
PROXY_BASE_URL=

# 프록시/도서관 로그인 페이지 URL — 자동 재로그인 시 사용됩니다.
# 예시(허구):
#   https://your-library.your-univ.edu/login
PROXY_LOGIN_URL=

# 프록시 동작 검증용 테스트 URL — 비어두면 https://www.nature.com 사용
PROXY_VERIFY_URL=

# 로그인 폼 셀렉터 — 기관마다 다를 수 있어 커스터마이징 가능합니다.
# 비어두면 기본값을 사용합니다(아이디=#user-id, 비밀번호=#user-pw,
# 제출 버튼=button[type="submit"]).
PROXY_LOGIN_ID_SELECTOR=
PROXY_LOGIN_PW_SELECTOR=
PROXY_LOGIN_SUBMIT_SELECTOR=
# (선택) 로그인 페이지에서 미리 클릭해야 하는 라디오/체크박스 셀렉터
# 예: 포털ID/직원ID 등 사용자 유형 선택 라디오
PROXY_LOGIN_PRECLICK_SELECTOR=

# 자동 로그인용 자격 증명
PROXY_PORTAL_ID=
PROXY_PORTAL_PW=


# ── 티어 1 API (전문 수집용) ─────────────────────────────────────────
# UNPAYWALL_EMAIL은 필수(아무 이메일이나 가능),
# 나머지는 선택 — 비어있으면 자동 스킵됩니다.

UNPAYWALL_EMAIL=

# Semantic Scholar (rate limit 완화용)
SEMANTIC_SCHOLAR_API_KEY=

# 출판사 TDM API (대학 구독이 있는 경우)
ELSEVIER_API_KEY=
SPRINGER_API_KEY=
SPRINGER_META_API_KEY=
WILEY_TDM_TOKEN=
CORE_API_KEY=


# ── Notion MCP (Phase 8 결과 기록용) ────────────────────────────────
# /research-notion 스킬이 결과를 노션 DB/페이지로 기록할 때 사용합니다.
# bash scripts/setup-proxy.sh 에서 대화형으로 입력받을 수 있고,
# 여기에 직접 적어도 됩니다. 값이 비어 있으면 .mcp.json 의 notion 서버는
# 인증 실패하므로 Phase 8 은 실행되지 않고 스킵됩니다.
#
# - 토큰 발급: https://www.notion.so/profile/integrations
#   → "New integration" → Internal Integration Token 복사
#   (ntn_... 또는 secret_... 으로 시작)
# - 부모 페이지: 결과를 담을 노션 페이지 하나를 만들고, 해당 페이지를
#   위 Integration 에 "Connect" 로 공유. 페이지 URL 말미의 32자가 ID.
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
